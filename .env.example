# Copy this file to `.env.local` and fill in values. `.env.local` is gitignored.

# Vite only exposes variables prefixed with `VITE_` to client code.



# Google AI (Gemini) — https://aistudio.google.com/app/apikey

VITE_GEMINI_API_KEY=

VITE_GEMINI_MODEL=gemini-2.5-flash

# Optional: same key as VITE_GEMINI_API_KEY for server-only routes (POST /api/jobs/personalized).

# If unset, the server falls back to VITE_GEMINI_API_KEY from .env.local.

# GEMINI_API_KEY=

# GEMINI_MODEL=gemini-2.0-flash



# Firebase — Firebase Console → Project settings → General → Your apps (Web)

VITE_FIREBASE_API_KEY=

VITE_FIREBASE_AUTH_DOMAIN=

VITE_FIREBASE_PROJECT_ID=

VITE_FIREBASE_STORAGE_BUCKET=

VITE_FIREBASE_MESSAGING_SENDER_ID=

VITE_FIREBASE_APP_ID=

# Optional: full URL of your backend POST endpoint for LinkedIn profile import

# VITE_LINKEDIN_IMPORT_API=



# =============================================================================

# Relevance AI — LinkedIn import (server/relevanceLinkedIn.ts)

# =============================================================================

# Restart `npm run dev` after editing. No `VITE_` prefix — server only.

#

# --- Option A: Async (recommended if your tool runs > ~30 seconds) ---

# When RELEVANCEAI_REGION + RELEVANCEAI_TOOL_ID + RELEVANCEAI_PROJECT_ID are all set,

# the server uses trigger_async + polling (no 30s sync limit).

# Authorization header = `project_id:api_key` (API Keys page in Relevance).

#

# RELEVANCEAI_REGION=bcbe5a

#   # Subdomain only: from https://api-<REGION>.stack.tryrelevance.com

# RELEVANCEAI_TOOL_ID=4b51cdf1-f328-477e-a4c4-b3760406073a

#   # Studio id in the URL path: /studios/<TOOL_ID>/trigger_async

# RELEVANCEAI_PROJECT_ID=cb85d7bc-d73e-46a2-8622-a7c6297d128f

#   # Project id (same as in `project` JSON field)

# RELEVANCEAI_API_KEY=your_secret_key

#   # Used as Authorization: RELEVANCEAI_PROJECT_ID:RELEVANCEAI_API_KEY

# Optional: set full Authorization instead (overrides project:key build):

# RELEVANCEAI_AUTHORIZATION=project_uuid:secret_key

#

# Optional async tuning:

# RELEVANCEAI_USE_ASYNC=true

#   # Force async (default is already "on" when region+tool+project are set). Set to false to force sync webhook.

# RELEVANCEAI_ASYNC_MAX_MS=600000

#   # Max wait for job (default 10 minutes)

# RELEVANCEAI_ASYNC_POLL_MS=3000

#   # Poll interval (default 3 seconds)

#

# Async request body: params = { "url": "<linkedin profile>", "name": "" } — align your tool inputs.

#

# --- Option B: Synchronous webhook (under ~30s) ---

# RELEVANCEAI_WEBHOOK_URL=https://api-....tryrelevance.com/latest/studios/.../trigger_webhook?project=...

# RELEVANCEAI_API_KEY=

#   # For sync, paste the key as Relevance shows (may differ from project:secret format).

#

# If you saw HTTP 405 from sync: see server/relevanceLinkedIn.ts (postTriggerWebhook redirect fix).

#

# RELEVANCEAI_WEBHOOK_URL=

# RELEVANCEAI_API_KEY=



# =============================================================================

# Job listings (server/jobsAggregator.ts)

# =============================================================================

# Indeed/LinkedIn RSS often return HTTP 403 or drop TLS for server-side fetches — not fixable with Windows settings.

# For reliable listings, register for free API keys at https://developer.adzuna.com/signup (non-commercial / fair-use).

#

# ADZUNA_APP_ID=

# ADZUNA_APP_KEY=

#   (alias: ADZUNA_API_KEY — same as app_key if your dashboard labels it “API key” only)

# Optional: search query. Use commas for multiple (different majors / roles), e.g.:

# ADZUNA_QUERY_WHAT=software engineering intern, marketing intern, nursing student, finance intern

# ADZUNA_QUERY_WHAT=software engineering intern

# ADZUNA_QUERY_WHERE=California

# Max results per Adzuna request (1–50; default 25). Free tiers may cap lower.

# ADZUNA_RESULTS_PER_PAGE=25

# Cap on /api/jobs list length after merge/dedupe (default 40, max 80)

# JOBS_AGGREGATE_MAX=40

# Verbose Indeed/LinkedIn RSS logs (403/404 are normal for server-side; leave unset)

# JOBS_RSS_DEBUG=1


